---
const {as: Tag = 'span', targets, color = 'muted'} = Astro.props
---

<Tag
  data-component="trigger"
  data-options={JSON.stringify({targets})}
  class="trigger inline-block rounded-full text-lightest cursor-pointer transition duration-250 ease-in-out px-2xs pt-0.5 pb-1 font-thin hover:shadow-sm"
  style=`--trigger-color: var(--color-${color})`
>
  <slot />
</Tag>

<style>
  .trigger {
    --trigger-color: var(--color-muted);
    background: color-mix(in oklab, var(--trigger-color) 75%, transparent);
    line-height: 1.15;
  }

  .trigger:hover {
    background: var(--trigger-color);
  }
</style>
